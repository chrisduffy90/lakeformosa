---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupStrip from '../components/SignupStrip.astro';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const apiUrl = import.meta.env.PUBLIC_API_URL;
---

<BaseLayout title="About | Lake Formosa Neighborhood Association">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Our Neighborhood</h1>
      <p>The history, character, and community of Lake Formosa.</p>
    </div>
  </div>

  <!-- HISTORY -->
  <section class="surface">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">History</span>
        <div class="section-body">
          <h2 class="section-heading">A neighborhood shaped by its lake</h2>
          <p>Lake Formosa is one of Orlando's most distinctive urban neighborhoods, centered around the shimmering 70-acre lake that gives it its name. Bordered by the Loch Haven Cultural Park, home to the Orlando Museum of Art, the Orlando Science Center, and the Orlando Repertory Theatre, the neighborhood blends natural beauty with a rich civic life that has been building since the early 20th century.</p>
          <p>The area features craftsman bungalows, mid-century modern homes, and newer infill housing woven together by a mature tree canopy and streets that remain genuinely walkable. Proximity to Mills Avenue, the cultural park, and downtown Orlando make it one of central Florida's most sought-after addresses.</p>
          <p>The Lake Formosa Neighborhood Association was founded to preserve that character by advocating at city hall on zoning and development decisions, organizing the community around shared concerns, and protecting the lake and green spaces that define the neighborhood's identity.</p>
        </div>
      </div>

      <!-- MAP: full container width below the text grid -->
      <div class="map-container fade-in">
        <div id="map"></div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section>
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Mission</span>
        <div class="section-body">
          <h2 class="section-heading">What we stand for</h2>
          <p><strong style="font-weight: 500; color: var(--text-primary);">Advocacy.</strong> We represent resident interests at City Hall, in front of planning and zoning boards, and with elected officials on every issue that affects our neighborhood.</p>
          <p><strong style="font-weight: 500; color: var(--text-primary);">Community.</strong> Monthly meetings, volunteer events, and block parties that build the kind of connections that make a neighborhood more than a collection of houses.</p>
          <p><strong style="font-weight: 500; color: var(--text-primary);">Stewardship.</strong> We work to protect the lake's water quality, the neighborhood's tree canopy, and the historic character of the built environment.</p>
          <p><strong style="font-weight: 500; color: var(--text-primary);">Communication.</strong> We keep residents informed and make it easy to get involved, whether that's attending a meeting, joining a committee, or just signing up for updates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GET INVOLVED -->
  <section class="surface" id="get-involved">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Get Involved</span>
        <div>
          <h2 class="section-heading">Live in Lake Formosa? We want to hear from you.</h2>
          <p class="get-involved-intro">Whether you want to attend a meeting, volunteer for an event, join a committee, or eventually serve on the board — fill out this form and someone will be in touch. The more neighbors who participate, the stronger the association.</p>

          <form
            class="get-involved-form"
            id="get-involved-form"
            novalidate
          >

            <div class="gi-row-2">
              <div class="gi-field">
                <label for="gi-first">First Name</label>
                <input type="text" id="gi-first" name="first_name" autocomplete="given-name" required />
              </div>
              <div class="gi-field">
                <label for="gi-last">Last Name</label>
                <input type="text" id="gi-last" name="last_name" autocomplete="family-name" required />
              </div>
            </div>

            <div class="gi-field">
              <label for="gi-email">Email Address</label>
              <input type="email" id="gi-email" name="email" autocomplete="email" required />
            </div>

            <div class="gi-field">
              <label for="gi-address">Street Address <span class="gi-hint">(to confirm you live in the neighborhood)</span></label>
              <input type="text" id="gi-address" name="address" autocomplete="street-address" />
            </div>

            <div class="gi-field">
              <label>I am interested in</label>
              <div class="gi-checkboxes">
                <label class="gi-check"><input type="checkbox" name="interests" value="Attending monthly meetings" /> Attending monthly meetings</label>
                <label class="gi-check"><input type="checkbox" name="interests" value="Volunteering for events" /> Volunteering for events</label>
                <label class="gi-check"><input type="checkbox" name="interests" value="Joining a committee" /> Joining a committee</label>
                <label class="gi-check"><input type="checkbox" name="interests" value="Serving on the board" /> Serving on the board</label>
                <label class="gi-check"><input type="checkbox" name="interests" value="Just staying informed" /> Just staying informed</label>
              </div>
            </div>

            <span class="field-error" id="gi-error"></span>
            <button type="submit" class="gi-submit" id="gi-btn">Submit →</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <SignupStrip
    heading="Just want event reminders?"
    subtext="Sign up for email updates and we'll keep you posted on meetings and community events."
  />
</BaseLayout>

<!-- Mapbox -->
<link href="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.js" is:inline></script>

<script define:vars={{ mapboxToken, apiUrl }}>
  mapboxgl.accessToken = mapboxToken;

  const map = new mapboxgl.Map({
    container: 'map',
    style: 'mapbox://styles/chrisduffy90/cmmgqwd3h003101qn19rk2mdw',
    center: [-81.36974, 28.56835],
    zoom: 14.5,
    pitch: 25,
    scrollZoom: false,
  });

  map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');

  const el = document.createElement('div');
  el.style.cssText = `
    width: 10px; height: 10px;
    background: #3d5a4f; border: 2px solid white;
    border-radius: 50%; box-shadow: 0 2px 6px rgba(0,0,0,0.3); cursor: pointer;
  `;
  new mapboxgl.Marker(el)
    .setLngLat([-81.36974, 28.56835])
    .setPopup(new mapboxgl.Popup({ offset: 15 }).setHTML('<strong>Lake Formosa</strong><br>Orlando, FL'))
    .addTo(map);

  // TODO: add neighborhood overlay once GeoJSON is available from City of Orlando GIS
  // map.on('load', () => {
  //   map.addSource('boundary', { type: 'geojson', data: BOUNDARY_GEOJSON });
  //   map.addLayer({ id: 'boundary-fill', type: 'fill', source: 'boundary',
  //     paint: { 'fill-color': '#3d5a4f', 'fill-opacity': 0.1 } });
  //   map.addLayer({ id: 'boundary-line', type: 'line', source: 'boundary',
  //     paint: { 'line-color': '#3d5a4f', 'line-width': 1.5 } });
  // });

  if (window.innerWidth <= 768) {
    map.dragPan.disable();
    map.touchZoomRotate.disable();
  }

  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Get Involved form
  const giForm  = document.getElementById('get-involved-form');
  const giBtn   = document.getElementById('gi-btn');
  const giError = document.getElementById('gi-error');

  if (giForm) {
    giForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      giError.textContent = '';

      const first_name = giForm.querySelector('#gi-first').value.trim();
      const last_name  = giForm.querySelector('#gi-last').value.trim();
      const email      = giForm.querySelector('#gi-email').value.trim();
      const address    = giForm.querySelector('#gi-address').value.trim();
      const interests  = Array.from(giForm.querySelectorAll('input[name="interests"]:checked')).map(i => i.value);

      if (!first_name || !email) {
        giError.textContent = 'Please fill in your name and email address.';
        return;
      }

      giBtn.textContent = 'Submitting...'; giBtn.disabled = true;

      try {
        const res = await fetch(`${apiUrl}/get-involved`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ first_name, last_name, email, address, interests }),
        });
        if (res.ok) {
          giBtn.textContent = 'Submitted ✓'; giBtn.style.opacity = '0.6';
          giForm.querySelectorAll('input[type="text"], input[type="email"]').forEach(i => i.value = '');
          giForm.querySelectorAll('input[type="checkbox"]').forEach(i => i.checked = false);
        } else { throw new Error(); }
      } catch {
        giError.textContent = 'Something went wrong. Please try again.';
        giBtn.textContent = 'Submit →'; giBtn.disabled = false;
      }
    });
  }
</script>

<style>
  /* ── GET INVOLVED FORM ── */
  .get-involved-intro {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .get-involved-form { display: flex; flex-direction: column; gap: 1rem; }

  .gi-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .gi-field { display: flex; flex-direction: column; gap: 0.35rem; }

  .gi-field label {
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .gi-hint { text-transform: none; letter-spacing: 0; font-size: 0.68rem; color: var(--text-secondary); opacity: 0.75; }

  .gi-field input {
    width: 100%;
    background: rgba(255,255,255,0.7);
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 0.7rem 0.9rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
  }

  .gi-field input:focus { border-color: var(--accent); }

  .gi-checkboxes {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }

  .gi-check {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    cursor: pointer;
    text-transform: none;
    letter-spacing: 0;
    font-weight: 300;
  }

  .gi-check input[type="checkbox"] {
    width: 15px;
    height: 15px;
    accent-color: var(--accent);
    flex-shrink: 0;
    padding: 0;
    border: none;
  }

  .gi-submit {
    align-self: flex-start;
    background: var(--text-primary);
    color: var(--bg);
    border: none;
    padding: 0.8rem 1.75rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .gi-submit:hover { opacity: 0.8; }

  @media (max-width: 540px) {
    .gi-row-2 { grid-template-columns: 1fr; }
  }

  /* ── MAP ── */
  .map-container {
    margin-top: 3rem;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  #map { width: 100%; height: 440px; }
</style>
