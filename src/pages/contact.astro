---
import BaseLayout from '../layouts/BaseLayout.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL;
---

<BaseLayout title="Contact | Lake Formosa Neighborhood Association">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Contact Us</h1>
      <p>Reach the board, flag a neighborhood concern, or find out how to get more involved.</p>
    </div>
  </div>

  <section class="surface">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Get in Touch</span>
        <div>
          <h2 class="section-heading">Send a message</h2>
          <div class="two-col">
            <!-- FORM -->
            <form id="contact-form" novalidate>
              <div class="form-row">
                <label for="c-name">Your Name</label>
                <input type="text" id="c-name" required placeholder="Jane Smith" />
              </div>
              <div class="form-row">
                <label for="c-email">Email Address</label>
                <input type="email" id="c-email" required placeholder="jane@example.com" />
              </div>
              <div class="form-row">
                <label for="c-subject">Topic</label>
                <select id="c-subject">
                  <option value="General question">General question</option>
                  <option value="Meeting or events">Meeting or events</option>
                  <option value="Neighborhood concern">Neighborhood concern</option>
                  <option value="Board or membership">Board or membership</option>
                  <option value="Volunteering">Volunteering</option>
                  <option value="Gallery photo submission">Gallery photo submission</option>
                  <option value="Media inquiry">Media inquiry</option>
                </select>
              </div>
              <div class="form-row">
                <label for="c-message">Message</label>
                <textarea id="c-message" required placeholder="How can we help?"></textarea>
              </div>
              <span class="field-error" id="c-error"></span>
              <button type="submit" class="btn-submit" id="c-btn">Send Message →</button>
            </form>

            <!-- CONTACT INFO -->
            <div class="contact-info-list">
              <div class="contact-info-item">
                <div class="contact-info-label">Email</div>
                <a href="mailto:info@lakeformosa.org">info@lakeformosa.org</a>
              </div>
              <div class="contact-info-item">
                <div class="contact-info-label">Monthly Meetings</div>
                Second Tuesday of each month<br />
                7:00 PM · All residents welcome<br />
                <a href="https://maps.google.com/?q=2267+N+Mills+Ave+Orlando+FL+32803" target="_blank" rel="noopener">
                  Loch Haven Park Pavilion<br />2267 N Mills Ave, Orlando FL 32803
                </a>
              </div>
              <div class="contact-info-item">
                <div class="contact-info-label">Non-Emergency Police</div>
                Orlando Police Dept<br />
                <a href="tel:+14072462470">(407) 246-2470</a>
              </div>
              <div class="contact-info-item">
                <div class="contact-info-label">City of Orlando</div>
                <a href="https://www.orlando.gov/Resident-Services/City-311" target="_blank" rel="noopener">
                  City 311: Report a neighborhood issue →
                </a>
              </div>
              <div class="contact-info-item">
                <div class="contact-info-label">Dues &amp; Membership</div>
                <a href="/dues">Pay dues or check membership status →</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ apiUrl }}>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  const form  = document.getElementById('contact-form');
  const btn   = document.getElementById('c-btn');
  const error = document.getElementById('c-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    error.textContent = '';

    const name    = document.getElementById('c-name').value.trim();
    const email   = document.getElementById('c-email').value.trim();
    const subject = document.getElementById('c-subject').value;
    const message = document.getElementById('c-message').value.trim();

    if (!name || !email || !message) {
      error.textContent = 'Please fill in your name, email, and message.';
      return;
    }

    btn.textContent = 'Sending...'; btn.disabled = true;

    try {
      const res = await fetch(`${apiUrl}/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, subject, message }),
      });

      if (res.ok) {
        btn.textContent = 'Message sent ✓'; btn.style.opacity = '0.6';
        form.querySelectorAll('input, textarea').forEach(i => i.value = '');
      } else {
        throw new Error();
      }
    } catch {
      error.textContent = 'Something went wrong. Please try again or email us directly.';
      btn.textContent = 'Send Message →'; btn.disabled = false;
    }
  });
</script>
