---
import BaseLayout from '../layouts/BaseLayout.astro';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <h1>Welcome to Lake Formosa</h1>
    <p class="subtitle">
      A vibrant, historic neighborhood in the heart of Orlando — united by our lake, our parks, and our community.
    </p>
    <div class="hero-actions">
      <a href="/events" class="btn btn-primary">Upcoming Events</a>
      <a href="/about" class="btn btn-outline">Learn More</a>
    </div>
  </section>

  <!-- QUICK LINKS -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Get Involved</h2>
      <hr class="divider" />
      <p class="section-lead">Everything you need to connect with your neighbors and make Lake Formosa a better place to live.</p>
      <div class="cards">
        <div class="card">
          <div class="card-icon">📅</div>
          <h3>Monthly Meetings</h3>
          <p>Join us the second Tuesday of every month at the Loch Haven Park pavilion. All residents welcome.</p>
        </div>
        <div class="card">
          <div class="card-icon">📣</div>
          <h3>Announcements</h3>
          <p>Stay up to date on neighborhood news, city planning updates, and local events affecting our community.</p>
        </div>
        <div class="card">
          <div class="card-icon">🏘️</div>
          <h3>Neighborhood Watch</h3>
          <p>Collaborate with neighbors and OPD to keep Lake Formosa safe. Report concerns and share resources.</p>
        </div>
        <div class="card">
          <div class="card-icon">🌿</div>
          <h3>Green Spaces</h3>
          <p>Help maintain and improve our parks, lake access, and green corridors throughout the neighborhood.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Neighborhood</h2>
      <hr class="divider" />
      <p class="section-lead">Lake Formosa sits in the heart of Orlando, bordered by Loch Haven Park and the city's cultural district.</p>
      <div id="map"></div>
    </div>
  </section>

  <!-- UPCOMING EVENTS PREVIEW -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">Upcoming Events</h2>
      <hr class="divider" />
      <div class="event-list">
        <div class="event-item">
          <div class="event-date"><div class="month">May</div><div class="day">13</div></div>
          <div class="event-info">
            <h3>Monthly Neighborhood Meeting</h3>
            <p>7:00 PM &middot; Loch Haven Park Pavilion &middot; All residents welcome</p>
          </div>
        </div>
        <div class="event-item">
          <div class="event-date"><div class="month">May</div><div class="day">24</div></div>
          <div class="event-info">
            <h3>Lake Cleanup Day</h3>
            <p>9:00 AM &middot; Lake Formosa Shoreline &middot; Bring gloves and bags</p>
          </div>
        </div>
        <div class="event-item">
          <div class="event-date"><div class="month">Jun</div><div class="day">10</div></div>
          <div class="event-info">
            <h3>Summer Block Party</h3>
            <p>5:00 PM &middot; Neighborhood Park &middot; Food, music, and family fun</p>
          </div>
        </div>
      </div>
      <p style="margin-top: 1.5rem;"><a href="/events" class="btn btn-primary">View All Events</a></p>
    </div>
  </section>
</BaseLayout>

<!-- Mapbox -->
<link href="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v3.17.0/mapbox-gl.js" is:inline></script>

<script define:vars={{ mapboxToken }}>
  mapboxgl.accessToken = mapboxToken;

  const map = new mapboxgl.Map({
    container: 'map',
    style: 'mapbox://styles/mapbox/outdoors-v12',
    center: [-81.3751, 28.5618], // Lake Formosa, Orlando
    zoom: 14.5,
  });

  map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');

  // Marker on the lake
  new mapboxgl.Marker({ color: '#1a3a5c' })
    .setLngLat([-81.3751, 28.5618])
    .setPopup(new mapboxgl.Popup({ offset: 15 }).setHTML('<strong>Lake Formosa</strong><br>Orlando, FL'))
    .addTo(map);

  // TODO: add neighborhood boundary polygon here when you have the GeoJSON from
  // City of Orlando GIS portal (https://data.cityoforlando.net).
  // map.on('load', () => {
  //   map.addSource('boundary', { type: 'geojson', data: BOUNDARY_GEOJSON });
  //   map.addLayer({ id: 'boundary-fill', type: 'fill', source: 'boundary',
  //     paint: { 'fill-color': '#1a3a5c', 'fill-opacity': 0.12 } });
  //   map.addLayer({ id: 'boundary-line', type: 'line', source: 'boundary',
  //     paint: { 'line-color': '#1a3a5c', 'line-width': 2 } });
  // });
</script>

<style>
  #map { margin-top: 0; }
</style>
