---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const members = await getCollection('board');
  return members.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { name, role, bio, email, headshot } = entry.data;

function initials(n: string) {
  if (n === 'Open Position') return '?';
  return n.split(' ').slice(0, 2).map((w: string) => w[0]).join('').toUpperCase();
}
---

<BaseLayout title={`${name} | Lake Formosa Neighborhood Association`}>
  <div class="page-hero">
    <div class="page-hero-inner">
      <a href="/board" class="back-link">← Board of Directors</a>
    </div>
  </div>

  <section class="surface">
    <div class="section-inner">
      <div class="bio-layout fade-in">

        <!-- AVATAR -->
        <div class="bio-avatar-col">
          <div class="bio-avatar">
            {headshot
              ? <img src={headshot} alt={name} />
              : <span>{initials(name)}</span>
            }
          </div>
        </div>

        <!-- INFO -->
        <div class="bio-info">
          <div class="bio-role">{role}</div>
          <h1 class="bio-name">{name}</h1>
          <p class="bio-body">{bio}</p>
          {email && (
            <a href={`mailto:${email}`} class="bio-email">{email}</a>
          )}
          <div class="bio-footer">
            <a href="/board" class="text-link">← Back to the board</a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    font-size: 0.82rem;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--text-primary); }

  .page-hero-inner { padding-bottom: 2rem; }

  .bio-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .bio-avatar-col { padding-top: 0.25rem; }

  .bio-avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bio-avatar span {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .bio-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .bio-role {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .bio-name {
    font-family: 'DM Serif Display', serif;
    font-size: 2.2rem;
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }

  .bio-body {
    font-size: 0.97rem;
    color: var(--text-secondary);
    line-height: 1.85;
    margin-bottom: 1.5rem;
    max-width: 560px;
  }

  .bio-email {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-bottom: 2.5rem;
  }

  .bio-footer { border-top: 1px solid var(--border); padding-top: 1.5rem; margin-top: 1rem; }

  @media (max-width: 640px) {
    .bio-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .bio-avatar { width: 110px; height: 110px; }
    .bio-avatar span { font-size: 2rem; }
    .bio-name { font-size: 1.7rem; }
  }
</style>

<script is:inline>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
