---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allMembers = await getCollection('board');
const sorted = allMembers.sort((a, b) => a.data.order - b.data.order);

const officers = sorted.filter(m => m.data.role !== 'Member at Large');
const members  = sorted.filter(m => m.data.role === 'Member at Large');

function initials(name: string) {
  if (name === 'Open Position') return '?';
  return name.split(' ').slice(0, 2).map((w: string) => w[0]).join('').toUpperCase();
}
---

<BaseLayout title="Board | Lake Formosa Neighborhood Association">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Board of Directors</h1>
      <p>Meet the neighbors who keep the association running. Positions are elected annually at the December general meeting.</p>
    </div>
  </div>

  <!-- GET INVOLVED CTA -->
  <section>
    <div class="section-inner">
      <div class="cta-bar fade-in">
        <div>
          <div class="cta-label">Live in the neighborhood?</div>
          <div class="cta-heading">Get involved with the association</div>
        </div>
        <a href="/about#get-involved" class="cta-btn">Tell us you're interested →</a>
      </div>
    </div>
  </section>

  <!-- OFFICERS -->
  <section class="surface">
    <div class="section-inner">
      <div class="board-section-label fade-in">Officers</div>
      <div class="officer-grid fade-in">
        {officers.map(entry => (
          <a href={`/board/${entry.id}`} class="officer-card">
            <div class="officer-avatar">
              {entry.data.headshot
                ? <img src={entry.data.headshot} alt={entry.data.name} />
                : <span>{initials(entry.data.name)}</span>
              }
            </div>
            <div class="officer-role">{entry.data.role}</div>
            <div class="officer-name">{entry.data.name}</div>
            <p class="officer-bio">{entry.data.bio}</p>
            <span class="officer-more">View bio →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MEMBERS AT LARGE -->
  <section>
    <div class="section-inner">
      <div class="board-section-label fade-in">Members at Large</div>
      <div class="member-grid fade-in">
        {members.map(entry => (
          <a href={`/board/${entry.id}`} class="member-card">
            <div class="member-avatar">
              {entry.data.headshot
                ? <img src={entry.data.headshot} alt={entry.data.name} />
                : <span>{initials(entry.data.name)}</span>
              }
            </div>
            <div class="member-name">{entry.data.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ELECTIONS -->
  <section class="surface">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Elections</span>
        <div class="section-body">
          <h2 class="section-heading">How board elections work</h2>
          <p>Elections are held at the December general meeting each year. Any resident who lives within the Lake Formosa neighborhood is eligible to run for a board seat. Nominations open in November and are announced via email and at the November meeting.</p>
          <p>Voting is open to all dues-paying members present at the December meeting. Board terms run January through December of the following year.</p>
          <div class="info-box">
            <strong>Interested in serving?</strong> Nominations open in November each year. Any Lake Formosa resident can run. <a href="/contact">Send us a note</a> if you'd like to learn more before nominations open.
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .board-section-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.75rem;
  }

  /* ── CTA BAR ── */
  .cta-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .cta-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }
  .cta-heading {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text-primary);
  }
  .cta-btn {
    background: var(--accent);
    color: #fff;
    padding: 0.7rem 1.4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    border-radius: 2px;
    white-space: nowrap;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .cta-btn:hover { opacity: 0.85; text-decoration: none; }

  /* ── OFFICER CARDS ── */
  .officer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .officer-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: inherit;
    transition: background 0.2s, border-color 0.2s;
  }

  .officer-card:hover {
    background: var(--accent-light);
    border-color: var(--accent);
    text-decoration: none;
  }

  .officer-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .officer-avatar span {
    font-family: 'DM Serif Display', serif;
    font-size: 1.3rem;
    color: #fff;
    letter-spacing: 0.02em;
  }

  .officer-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .officer-role {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.3rem;
  }

  .officer-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .officer-bio {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .officer-more {
    font-size: 0.78rem;
    color: var(--accent);
    margin-top: 1rem;
    letter-spacing: 0.02em;
  }

  /* ── MEMBER CARDS ── */
  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .member-card {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    color: inherit;
    transition: background 0.2s, border-color 0.2s;
  }

  .member-card:hover {
    background: var(--accent-light);
    border-color: var(--accent);
    text-decoration: none;
  }

  .member-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.85rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .member-avatar span {
    font-family: 'DM Serif Display', serif;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .member-avatar img { width: 100%; height: 100%; object-fit: cover; }

  .member-name {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 780px) {
    .officer-grid { grid-template-columns: 1fr; }
    .member-grid  { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 480px) {
    .member-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script is:inline>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
