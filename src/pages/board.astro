---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allMembers = await getCollection('board');
const members = allMembers.sort((a, b) => a.data.order - b.data.order).map(m => m.data);

function initials(name: string) {
  if (name === 'Open Position') return '?';
  return name.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
}
---

<BaseLayout title="Board — Lake Formosa Neighborhood Association">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Board of Directors</h1>
      <p>Meet the neighbors who keep the association running. All positions are elected annually at the December general meeting.</p>
    </div>
  </div>

  <section class="surface">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">2025 Board</span>
        <div>
          <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
            Board positions are currently open. If you live in the Lake Formosa neighborhood and are interested in serving, please <a href="/contact" style="color: var(--accent); text-decoration: underline; text-underline-offset: 2px;">reach out to us</a>.
          </p>
          <div class="board-grid">
            {members.map(member => (
              <div class="board-card">
                <div class="board-avatar">
                  {member.headshot
                    ? <img src={member.headshot} alt={member.name} />
                    : initials(member.name)
                  }
                </div>
                <div class="board-role">{member.role}</div>
                <div class="board-name">{member.name}</div>
                <p class="board-bio">{member.bio}</p>
                {member.email && (
                  <a
                    href={`mailto:${member.email}`}
                    style="font-size: 0.78rem; color: var(--accent); text-decoration: underline; text-underline-offset: 2px; margin-top: 0.6rem; display: inline-block;"
                  >{member.email}</a>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Elections</span>
        <div class="section-body">
          <h2 class="section-heading">How board elections work</h2>
          <p>Elections are held at the December general meeting each year. Any resident who lives within the Lake Formosa neighborhood is eligible to run for a board seat. Nominations open in November and are announced via email and at the November meeting.</p>
          <p>Voting is open to all dues-paying members present at the December meeting. Board terms run January through December of the following year.</p>
          <div class="info-box">
            <strong>Interested in running?</strong> You don't need prior experience — just a willingness to show up, represent your neighbors, and contribute a few hours each month. <a href="/contact">Send us a note</a> and we'll fill you in.
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
