---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');

const events = allEvents
  .sort((a, b) => a.data.date.localeCompare(b.data.date))
  .map(e => ({
    ...e.data,
    month: new Date(e.data.date + 'T00:00:00').toLocaleString('en-US', { month: 'short' }),
    day:   new Date(e.data.date + 'T00:00:00').toLocaleString('en-US', { day: 'numeric' }),
  }));
---

<BaseLayout title="Events — Lake Formosa Neighborhood Association">
  <div class="page-hero">
    <div class="page-hero-inner">
      <h1>Events &amp; Meetings</h1>
      <p>Everything coming up in the neighborhood — meetings, cleanups, and community gatherings.</p>
    </div>
  </div>

  <section class="surface">
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Calendar</span>
        <div>
          <h2 class="section-heading">Upcoming events</h2>
          <div class="event-list">
            {events.map(event => (
              <div class="event-row">
                <div class="event-date-block">
                  <div class="event-month">{event.month}</div>
                  <div class="event-day">{event.day}</div>
                </div>
                <div class="event-info">
                  <h3>{event.title}</h3>
                  <p class="event-meta">{event.time} · {event.location}</p>
                  <p class="event-desc">{event.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-inner">
      <div class="section-grid fade-in">
        <span class="section-label">Standing</span>
        <div class="section-body">
          <h2 class="section-heading">Regular meetings</h2>
          <p><strong style="font-weight: 500; color: var(--text-primary);">General meetings</strong> are held the second Tuesday of every month at 7:00 PM at the Loch Haven Park Pavilion, 2267 N Mills Ave, Orlando FL 32803. No membership required to attend.</p>
          <p><strong style="font-weight: 500; color: var(--text-primary);">Board meetings</strong> are held the first Monday of each quarter, open to residents. Contact us at least five days in advance to add an agenda item.</p>
          <div class="info-box">
            <strong>Have an event to add?</strong> If you're organizing a neighborhood activity, <a href="/contact">send us the details</a> and we'll list it here.
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
