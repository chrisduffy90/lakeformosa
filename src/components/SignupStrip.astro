---
interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = 'Stay in the loop',
  subtext  = 'Get event reminders and neighborhood news delivered to your inbox.',
} = Astro.props;
---

<section id="signup">
  <div class="signup-inner">
    <div class="signup-text fade-in">
      <h2>{heading}</h2>
      <p>{subtext}</p>
    </div>

    <form
      class="signup-form fade-in"
      id="signup-form"
      name="event-reminders"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      novalidate
    >
      <input type="hidden" name="form-name" value="event-reminders" />
      <p style="display:none;"><label>Skip: <input name="bot-field" /></label></p>

      <div class="signup-name-row">
        <input type="text" name="first_name" id="signup-first" placeholder="First name" autocomplete="given-name" />
        <input type="text" name="last_name"  id="signup-last"  placeholder="Last name"  autocomplete="family-name" />
      </div>
      <span class="field-error" id="signup-name-error"></span>

      <input type="email" name="email" id="signup-email" placeholder="Email address" autocomplete="email" required />
      <span class="field-error" id="signup-email-error"></span>

      <button type="submit" id="signup-btn">Get Updates →</button>
      <span class="field-error" id="signup-form-error"></span>
    </form>
  </div>
</section>

<style>
  .signup-name-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem;
  }

  @media (max-width: 400px) {
    .signup-name-row { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function () {
    const form       = document.getElementById('signup-form');
    const firstInput = document.getElementById('signup-first');
    const lastInput  = document.getElementById('signup-last');
    const emailInput = document.getElementById('signup-email');
    const nameError  = document.getElementById('signup-name-error');
    const emailError = document.getElementById('signup-email-error');
    const formError  = document.getElementById('signup-form-error');
    const btn        = document.getElementById('signup-btn');

    if (!form) return;

    function validEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()); }

    firstInput.addEventListener('input', () => { nameError.textContent = ''; });
    emailInput.addEventListener('input', () => { emailError.textContent = ''; });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      nameError.textContent = ''; emailError.textContent = ''; formError.textContent = '';

      const first = firstInput.value.trim();
      const email = emailInput.value.trim();
      let valid = true;

      if (!first) { nameError.textContent = 'Please enter your first name.'; valid = false; }
      if (!validEmail(email)) { emailError.textContent = 'Please enter a valid email address.'; valid = false; }
      if (!valid) return;

      btn.textContent = 'Submitting...'; btn.disabled = true;

      try {
        const body = new FormData(form);
        const res  = await fetch('/', { method: 'POST', body });

        if (res.ok) {
          btn.textContent = "You're on the list ✓";
          btn.style.opacity = '0.6';
          firstInput.value = ''; lastInput.value = ''; emailInput.value = '';
        } else {
          throw new Error('non-ok');
        }
      } catch {
        formError.textContent = 'Something went wrong. Please try again.';
        btn.textContent = 'Get Updates →'; btn.disabled = false;
      }
    });
  })();
</script>
